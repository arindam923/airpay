{
  "name": "airpay",
  "version": "0.1.0",
  "description": "Official AirPay Node.js SDK — crypto payment gateway for Solana, Ethereum, Arbitrum, and Polygon",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["airpay", "crypto", "payments", "solana", "ethereum", "arbitrum", "polygon", "usdc", "usdt"],
  "license": "MIT",
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
